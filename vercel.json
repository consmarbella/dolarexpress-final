{
  "rewrites": [
    {
      "source": "/public/:path*",
      "destination": "/public/:path*"
    },
    {
      "source": "/:path*.html",
      "destination": "/public/:path*.html"
    },
    {
      "source": "/:path*/",
      "destination": "/public/:path*.html"
    },
    {
      "source": "/:path*",
      "destination": "/public/:path*.html"
    }
  ]
}
